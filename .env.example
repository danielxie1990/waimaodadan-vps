# ─── Product Website CMS ──────────────────────────
# Copy this file to .env and fill in your values.
#
# For Docker users:
#   Edit docker-compose.yml instead — no .env file needed.
#   Just run: docker compose up -d

# ─── Database ─────────────────────────
# SQLite (zero setup — default)
DATABASE_URL="file:./dev.db"
# PostgreSQL (for high-traffic sites)
# DATABASE_URL="postgresql://user:password@localhost:5432/product_site"

# ─── Authentication ───────────────────
# Generate a random string (any random characters)
JWT_SECRET="change-this-to-a-random-string-in-production"
